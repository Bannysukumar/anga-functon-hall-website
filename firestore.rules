rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isBlocked() {
      return userExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == true;
    }

    function isAdmin() {
      return signedIn() &&
        userExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isReceptionist() {
      return signedIn() &&
        userExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "receptionist";
    }

    function staffExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function roleHasPermission(roleId, permission) {
      return roleId is string &&
        exists(/databases/$(database)/documents/roles/$(roleId)) &&
        permission in get(/databases/$(database)/documents/roles/$(roleId)).data.permissions;
    }

    function hasStaffPermission(permission) {
      return staffExists() &&
        (
          (
            staffDoc().data.effectivePermissions is list &&
            permission in staffDoc().data.effectivePermissions
          ) ||
          roleHasPermission(staffDoc().data.roleId, permission) ||
          (
            staffDoc().data.extraRoleIds is list &&
            staffDoc().data.extraRoleIds.size() > 0 &&
            roleHasPermission(staffDoc().data.extraRoleIds[0], permission)
          ) ||
          (
            staffDoc().data.extraRoleIds is list &&
            staffDoc().data.extraRoleIds.size() > 1 &&
            roleHasPermission(staffDoc().data.extraRoleIds[1], permission)
          ) ||
          (
            staffDoc().data.extraRoleIds is list &&
            staffDoc().data.extraRoleIds.size() > 2 &&
            roleHasPermission(staffDoc().data.extraRoleIds[2], permission)
          )
        );
    }

    function receptionistPermissionList() {
      return exists(/databases/$(database)/documents/settings/global)
        ? get(/databases/$(database)/documents/settings/global).data.receptionistPermissions
        : [];
    }

    function hasReceptionistPermission(permission) {
      return isReceptionist() &&
        receptionistPermissionList() is list &&
        permission in receptionistPermissionList();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin() || hasStaffPermission("SETTINGS_EDIT");
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create, update: if isAdmin() || hasStaffPermission("LISTINGS_CREATE_EDIT");
      allow delete: if isAdmin() || hasStaffPermission("LISTINGS_DELETE");
    }

    match /listings/{listingId}/units/{unitId} {
      allow read: if isAdmin() || hasStaffPermission("LISTINGS_VIEW");
      allow write: if isAdmin() || hasStaffPermission("LISTINGS_CREATE_EDIT");
    }

    match /users/{userId} {
      allow read: if isAdmin() ||
        hasStaffPermission("USERS_VIEW") ||
        (signedIn() && request.auth.uid == userId);
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if isAdmin() ||
        hasStaffPermission("USERS_BLOCK_UNBLOCK") ||
        (
          signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.isBlocked == resource.data.isBlocked &&
          request.resource.data.referredBy == resource.data.referredBy &&
          request.resource.data.referredByCode == resource.data.referredByCode &&
          request.resource.data.referrerName == resource.data.referrerName &&
          request.resource.data.referralCode == resource.data.referralCode &&
          request.resource.data.signupDate == resource.data.signupDate &&
          request.resource.data.mobileNumber == resource.data.mobileNumber &&
          request.resource.data.forcePasswordChange == resource.data.forcePasswordChange &&
          request.resource.data.createdByAdminUid == resource.data.createdByAdminUid &&
          request.resource.data.createdByAdminAt == resource.data.createdByAdminAt
        );
      allow delete: if isAdmin();
    }

    match /mobileNumbers/{mobileNumber} {
      allow read, write: if isAdmin();
    }

    match /referralCodeIndex/{code} {
      allow read, write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() ||
        hasStaffPermission("BOOKINGS_VIEW") ||
        hasReceptionistPermission("view_bookings") ||
        (signedIn() && resource.data.userId == request.auth.uid);
      // Booking creation is server-finalized only.
      allow create: if isAdmin() || hasStaffPermission("BOOKINGS_CREATE_MANUAL") || hasReceptionistPermission("create_booking");
      allow update: if isAdmin() ||
        hasStaffPermission("BOOKINGS_UPDATE_STATUS") ||
        hasReceptionistPermission("edit_booking") ||
        hasReceptionistPermission("cancel_booking") ||
        hasReceptionistPermission("check_in") ||
        hasReceptionistPermission("check_out") ||
        (
          signedIn() &&
          !isBlocked() &&
          resource.data.userId == request.auth.uid &&
          resource.data.status in ["pending", "confirmed"] &&
          request.resource.data.status == "cancelled" &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.totalAmount == resource.data.totalAmount &&
          request.resource.data.basePrice == resource.data.basePrice &&
          request.resource.data.addonsTotal == resource.data.addonsTotal &&
          request.resource.data.taxAmount == resource.data.taxAmount &&
          request.resource.data.serviceFee == resource.data.serviceFee &&
          request.resource.data.advancePaid == resource.data.advancePaid &&
          request.resource.data.dueAmount == resource.data.dueAmount
        );
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAdmin() ||
        hasStaffPermission("USERS_VIEW") ||
        hasReceptionistPermission("view_customers");
      allow create: if isAdmin() ||
        hasReceptionistPermission("create_customer");
      allow update: if isAdmin() ||
        hasReceptionistPermission("edit_customer");
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        hasStaffPermission("PAYMENTS_VIEW") ||
        hasReceptionistPermission("view_payments") ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || hasReceptionistPermission("create_payment_receipt");
    }

    match /bookingIntents/{intentId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if isAdmin() ||
        hasStaffPermission("BOOKINGS_VIEW") ||
        hasReceptionistPermission("view_bookings") ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAdmin() ||
        hasStaffPermission("PAYMENTS_VIEW") ||
        hasReceptionistPermission("view_payments") ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || hasReceptionistPermission("create_payment_receipt");
    }

    match /availabilityLocks/{lockId} {
      allow read: if true;
      // Needed for booking transaction from client app.
      allow create, update: if isAdmin() || (signedIn() && !isBlocked());
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if signedIn() && !isBlocked();
      allow write: if isAdmin() || hasStaffPermission("CMS_EDIT");
    }

    match /userWallets/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /walletTransactions/{txId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /referrals/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /scratchCards/{cardId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, delete: if isAdmin();
    }

    match /dailyRewards/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /spinUsage/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /referralDailyStats/{docId} {
      allow read, write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if signedIn();
      allow write: if isAdmin() || hasStaffPermission("CMS_EDIT");
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() || hasStaffPermission("SETTINGS_EDIT");
    }

    match /secureSettings/{docId} {
      allow read, write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if signedIn();
      allow write: if isAdmin() || hasStaffPermission("STAFF_ASSIGN_ROLE");
    }

    match /staff/{staffId} {
      allow read: if isAdmin() ||
        hasStaffPermission("ATTENDANCE_VIEW_ALL") ||
        hasStaffPermission("STAFF_ASSIGN_ROLE") ||
        (signedIn() && request.auth.uid == staffId);
      allow write: if isAdmin() || hasStaffPermission("STAFF_ASSIGN_ROLE");
    }

    match /workLocations/{locationId} {
      allow read: if signedIn();
      allow write: if isAdmin() || hasStaffPermission("SETTINGS_EDIT");
    }

    match /schedules/{scheduleId} {
      allow read: if signedIn();
      allow write: if isAdmin() || hasStaffPermission("SETTINGS_EDIT");
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() ||
        hasStaffPermission("ATTENDANCE_VIEW_ALL") ||
        (signedIn() && resource.data.userId == request.auth.uid);
      // Attendance creation is validated server-side (Cloud Function/admin only).
      allow create: if isAdmin() || hasStaffPermission("ATTENDANCE_MARK_FOR_OTHERS");
      allow update: if isAdmin() || hasStaffPermission("ATTENDANCE_MARK_FOR_OTHERS");
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() ||
        hasStaffPermission("BOOKINGS_UPDATE_STATUS") ||
        hasStaffPermission("STAFF_ASSIGN_ROLE") ||
        hasReceptionistPermission("edit_booking") ||
        hasReceptionistPermission("cancel_booking") ||
        hasReceptionistPermission("check_in") ||
        hasReceptionistPermission("check_out");
    }

    match /emailLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
